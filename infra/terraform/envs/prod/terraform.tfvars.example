aws_region   = "ap-south-1"
project_name = "tijoir"
environment  = "prod"

backend_image_tag = "bootstrap"

# First apply: false. After pushing a real backend image to ECR, set true.
enable_backend_lambda = false

# Replace after CloudFront is created if you want stricter CORS.
allowed_cors_origins = ["*"]

database_instance_class       = "db.t4g.micro"
database_allocated_storage    = 20
database_backup_retention_period = 0
database_deletion_protection  = true
redis_node_type               = "cache.t4g.micro"
lambda_memory_size            = 1024
lambda_timeout                = 30

notifications_enabled         = true
notification_expose_dev_tokens = true
notification_email_enabled    = false
notification_email_provider   = "noop"
notification_email_from_address = "no-reply@example.com"

# Google Sign-In (public OAuth Web client ID). Blank disables Google.
google_client_id = "306075557187-cmcq4g3p7rud2ettsuhs8ocl7h3qk9eo.apps.googleusercontent.com"
